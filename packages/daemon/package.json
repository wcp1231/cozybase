{
  "name": "@cozybase/daemon",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "cozybase": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "acp": "bun run src/acp/acp-entry.ts",
    "mcp:builder": "bun run src/mcp/mcp-entry.ts",
    "mcp:operator": "bun run src/ai/operator/mcp-entry.ts",
    "mcp:cozybase": "bun run src/ai/cozybase/mcp-entry.ts",
    "mcp": "bun run src/mcp/mcp-entry.ts",
    "sync:ui-guide-props": "bun run scripts/sync-ui-guide-props.ts",
    "check:ui-guide-props": "bun run scripts/sync-ui-guide-props.ts --check"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@cozybase/ai-runtime": "workspace:*",
    "@cozybase/builder-agent": "workspace:*",
    "@cozybase/cozybase-agent": "workspace:*",
    "@cozybase/operator-agent": "workspace:*",
    "@cozybase/runtime": "workspace:*",
    "@cozybase/ui": "workspace:*",
    "@mariozechner/pi-ai": "^0.16.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "croner": "^9.0.0",
    "hono": "^4.7.0",
    "jose": "^6.0.0",
    "nanoid": "^5.1.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
