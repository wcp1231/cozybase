{
  "name": "cozybase",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun packages/server/src/cli.ts daemon",
    "mcp": "bun packages/server/src/cli.ts mcp",
    "build:ui": "cd packages/ui && bun run build",
    "build:admin": "cd packages/admin && bun run build",
    "build:all": "bun run build:ui && bun run build:admin"
  }
}
