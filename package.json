{
  "name": "cozybase",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "desktop:prepare": "bun run scripts/desktop-prepare.ts",
    "build:daemon": "bun run desktop:prepare",
    "desktop:dev": "bun run scripts/desktop-dev.ts",
    "desktop:build": "bun run scripts/desktop-build.ts",
    "desktop:sign:adhoc": "bun run --filter @cozybase/desktop sign:adhoc",
    "desktop:package:nightly": "bun run --filter @cozybase/desktop package:nightly",
    "desktop:build:adhoc": "bun run desktop:build && bun run desktop:package:nightly",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "test": "bun run --workspaces --if-present test",
    "check": "bun run typecheck && bun run --filter @cozybase/daemon check:ui-guide-props"
  }
}
